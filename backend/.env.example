# =============================================================================
# AETRIX Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# For local development:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aetrix_db
POSTGRES_USER=aetrix_user
POSTGRES_PASSWORD=your_secure_password_here

# For Railway/Cloud deployment, use the provided DATABASE_URL or set:
# POSTGRES_HOST=your-db-host.railway.app
# POSTGRES_PORT=5432
# POSTGRES_DB=railway
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_railway_password

# -----------------------------------------------------------------------------
# Database Connection Pool
# -----------------------------------------------------------------------------
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT=30000

# -----------------------------------------------------------------------------
# JPA/Hibernate Configuration
# -----------------------------------------------------------------------------
# Options: none, validate, update, create, create-drop
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# -----------------------------------------------------------------------------
# Groq LLM API (Required for AI Summaries)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=500
GROQ_TEMPERATURE=0.3
GROQ_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Options: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL_APP=INFO
LOG_LEVEL_HIBERNATE=WARN

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# For development:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# For production (replace with your frontend URL):
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
CACHE_MAX_SIZE=200
CACHE_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Data Output Path (optional)
# -----------------------------------------------------------------------------
# DATA_OUTPUT_PATH=classpath:data/
