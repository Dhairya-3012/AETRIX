# =============================================================================
# AETRIX - Complete Environment Configuration
# =============================================================================
# This file contains ALL environment variables for the entire application.
# Copy this file to .env and fill in your values.
#
# For individual service deployment, use the respective .env.example files:
#   - backend/.env.example
#   - frontend/.env.example
#   - ML/.env.example
#
# DO NOT commit .env file to version control!
# =============================================================================


# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aetrix_db
POSTGRES_USER=aetrix_user
POSTGRES_PASSWORD=your_secure_password_here

# For Railway deployment, these are auto-provided via DATABASE_URL
# For other cloud providers, use their provided connection details


# =============================================================================
# BACKEND SERVICE (Spring Boot)
# =============================================================================
SERVER_PORT=8080

# Database Connection Pool
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT=30000

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Groq LLM API - Get key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=500
GROQ_TEMPERATURE=0.3

# Logging
LOG_LEVEL_APP=INFO
LOG_LEVEL_HIBERNATE=WARN

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cache
CACHE_MAX_SIZE=200
CACHE_EXPIRE_MINUTES=60


# =============================================================================
# FRONTEND SERVICE (React)
# =============================================================================
# MapTiler API - Get key from https://cloud.maptiler.com/account/keys/
REACT_APP_MAPTILER_KEY=your_maptiler_api_key_here

# Backend URL
REACT_APP_API_URL=http://localhost:8080

# ML Service URL (if running separately)
REACT_APP_ML_API_URL=http://localhost:8000


# =============================================================================
# ML SERVICE (Python/FastAPI)
# =============================================================================
ML_API_HOST=0.0.0.0
ML_API_PORT=8000
CSV_DATA_PATH=Ahmedabad_TimeSeries_Final.csv
OUTPUT_DIR=output
LOG_LEVEL=INFO
WORKERS=1


# =============================================================================
# DEPLOYMENT CONFIGURATION (Railway/Docker)
# =============================================================================
# NODE_ENV=production
# RAILWAY_ENVIRONMENT=production

# For Railway PostgreSQL, this is auto-provided:
# DATABASE_URL=postgresql://user:pass@host:port/db
