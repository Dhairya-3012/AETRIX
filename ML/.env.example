# =============================================================================
# AETRIX ML Service Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
ML_API_HOST=0.0.0.0
ML_API_PORT=8000

# -----------------------------------------------------------------------------
# Data Configuration
# -----------------------------------------------------------------------------
# Path to the CSV data file (relative to ML directory)
CSV_DATA_PATH=Ahmedabad_TimeSeries_Final.csv

# Output directory for generated JSON files
OUTPUT_DIR=output

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
# Enable/disable specific models
ENABLE_UHI_MODEL=true
ENABLE_VEGETATION_MODEL=true
ENABLE_POLLUTION_MODEL=true
ENABLE_FORECAST_MODEL=true

# -----------------------------------------------------------------------------
# CORS Configuration (if running standalone)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------------
# Number of workers for uvicorn (production)
WORKERS=1
